PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-name>.mongodb.net/taskdep?retryWrites=true&w=majority&appName=<cluster-name>
JWT_SECRET=CHANGE_ME_to_a_random_64_char_string
CLIENT_URL=http://localhost:5173
# Multiple origins can be comma-separated, e.g.
# CLIENT_URL=https://taskdep.vercel.app,https://www.taskdep.app

# Email configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_SECURE=false
FROM_EMAIL="TaskDep" <notifications@taskdep.com>

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
